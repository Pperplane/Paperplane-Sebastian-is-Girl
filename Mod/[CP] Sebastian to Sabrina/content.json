            }
        },
        
        {
            "LogName": "Sabrina Portrait Patch",
            "Action": "Include",
            "FromFile": "codes/portrait.json"
        },
        
        {
            "LogName": "Sabrina Sprite Patch",
            "Action": "Include",
            "FromFile": "codes/sprite.json"
        }
    ]
