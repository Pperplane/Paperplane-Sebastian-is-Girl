{

    "Format": "2.9.0",

    "DynamicTokens": [

        {
            "Name": "SabrinaAttire",
            "Value": "Sebastian_{{Season}}",
            "When": {
                "Season": "spring, summer, fall"
            }
        },
        {
            "Name": "SabrinaAttire",
            "Value": "Sebastian_winter_outdoor",
            "When": {
                "Season": "winter",
                "IsOutdoors": "true"
            }
        },
        {
            "Name": "SabrinaAttire",
            "Value": "Sebastian_winter_indoor",
            "When": {
                "Season": "winter",
                "IsOutdoors": "false"
            }
        },
        

        // Target File
        {
            "Name": "TargetSebastianFile",
            "Value": "Sebastian",
            "When": {
                "Season": "spring, summer, fall"
            }
        },
{
            "Name": "TargetSebastianFile",
            "Value": "Sebastian_Winter",
            "When": {
                "Season": "winter"
            }
        }

    ],

    "Changes": [
        
        {
            "LogName": "Sebastian Name Patch: Sebastian to Sabrina",
            "Action": "EditData",
            "Target": "Strings/NPCNames",
            "Entries": {
                "Sebastian": "Sabrina"
            }
        },

        {
            "LogName": "Change to {{Season}} Attire - Portrait",
            "Action": "EditImage",
            "Target": "Portraits/{{TargetSebastianFile}}",
            "FromFile":  "assets/portraits/{{SabrinaAttire}}.png",
            "Update": "OnLocationChange",
            "Priority": "Late"
        }
    ]
}